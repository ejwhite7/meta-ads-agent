# =============================================================================
# Meta Ads Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# --- Meta Platform -----------------------------------------------------------
# System user access token (permanent, no refresh needed)
# Required scopes: business_management, ads_management, pages_show_list,
#   pages_read_engagement, pages_manage_ads, catalog_management, read_insights
META_ACCESS_TOKEN=

# Ad account ID (format: act_XXXXXXXXX)
META_AD_ACCOUNT_ID=

# Meta app credentials (from developers.facebook.com)
META_APP_ID=
META_APP_SECRET=

# --- LLM Provider ------------------------------------------------------------
# Anthropic API key (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Which LLM provider to use: "claude" or "openai" (default: claude)
LLM_PROVIDER=claude

# Model identifier (default: claude-opus-4-5 for Claude, gpt-4o for OpenAI)
LLM_MODEL=

# --- Database ----------------------------------------------------------------
# Database mode: "sqlite" (local file) or "postgres" (cloud)
DATABASE_MODE=sqlite

# PostgreSQL connection string (required if DATABASE_MODE=postgres)
# Example: postgresql://user:password@localhost:5432/meta_ads_agent
DATABASE_URL=

# --- Dashboard ---------------------------------------------------------------
# Port for the dashboard API server (default: 3001)
DASHBOARD_PORT=3001

# API key for dashboard authentication (generate a random string)
DASHBOARD_API_KEY=

# Allowed CORS origin for the dashboard frontend (default: http://localhost:5173)
DASHBOARD_CORS_ORIGIN=http://localhost:5173

# Set to "none" to disable API key authentication (development only)
DASHBOARD_AUTH=

# --- Observability -----------------------------------------------------------
# Sentry DSN for error tracking (optional)
SENTRY_DSN=
