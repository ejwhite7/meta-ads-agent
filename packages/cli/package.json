{
  "name": "meta-ads-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "Open source autonomous agent for Meta Ads — full lifecycle campaign management, creative generation, and budget optimization",
  "keywords": ["meta", "facebook", "ads", "agent", "ai", "autonomous", "marketing", "advertising"],
  "license": "MIT",
  "bin": {
    "meta-ads-agent": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@meta-ads-agent/core": "workspace:*",
    "@meta-ads-agent/meta-client": "workspace:*",
    "boxen": "^8.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "inquirer": "^12.0.0",
    "ora": "^8.1.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@meta-ads-agent/tsconfig": "workspace:*",
    "@types/cli-table3": "^0.6.0",
    "@types/inquirer": "^9.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
