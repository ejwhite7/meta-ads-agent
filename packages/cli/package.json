{
	"name": "meta-ads-agent",
	"version": "0.3.2",
	"type": "module",
	"description": "Open source autonomous agent for Meta Ads — full lifecycle campaign management, creative generation, and budget optimization.",
	"keywords": [
		"meta",
		"facebook",
		"instagram",
		"ads",
		"advertising",
		"agent",
		"ai",
		"autonomous",
		"marketing",
		"automation",
		"ooda",
		"claude",
		"openai"
	],
	"license": "MIT",
	"author": "ejwhite7",
	"homepage": "https://github.com/ejwhite7/meta-ads-agent#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ejwhite7/meta-ads-agent.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/ejwhite7/meta-ads-agent/issues"
	},
	"bin": {
		"meta-ads-agent": "./dist/index.js",
		"maa": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"files": ["dist", "dashboard-static", "README.md", "LICENSE"],
	"engines": {
		"node": ">=20"
	},
	"publishConfig": {
		"access": "public",
		"provenance": false
	},
	"scripts": {
		"build": "tsup && pnpm build:dashboard:copy",
		"build:dashboard:copy": "node ./scripts/copy-dashboard-static.mjs",
		"build:tsc": "tsc --build",
		"dev": "tsup --watch",
		"cli": "tsx src/index.ts",
		"cli:prod": "node dist/index.js",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests",
		"start": "node dist/index.js",
		"clean": "rm -rf dist *.tsbuildinfo",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"@hono/node-server": "^1.13.0",
		"@sinclair/typebox": "^0.33.0",
		"axios": "^1.7.0",
		"better-sqlite3": "^11.0.0",
		"boxen": "^8.0.0",
		"chalk": "^5.3.0",
		"cli-table3": "^0.6.5",
		"commander": "^12.1.0",
		"drizzle-orm": "^0.36.0",
		"hono": "^4.6.0",
		"inquirer": "^12.0.0",
		"openai": "^4.75.0",
		"ora": "^8.1.0",
		"winston": "^3.15.0",
		"zod": "^3.23.0"
	},
	"optionalDependencies": {
		"pg": "^8.13.0"
	},
	"devDependencies": {
		"@meta-ads-agent/core": "workspace:*",
		"@meta-ads-agent/dashboard": "workspace:*",
		"@meta-ads-agent/meta-client": "workspace:*",
		"@meta-ads-agent/tsconfig": "workspace:*",
		"@types/better-sqlite3": "^7.6.0",
		"@types/inquirer": "^9.0.0",
		"@types/node": "^20.0.0",
		"tsup": "^8.3.0",
		"vitest": "^2.0.0"
	}
}
