{
	"name": "@meta-ads-agent/meta-client",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Meta API client — CLI wrapper (47 commands) and direct Marketing API client for meta-ads-agent",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsc --build",
		"dev": "tsc --build --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"clean": "rm -rf dist *.tsbuildinfo"
	},
	"dependencies": {
		"axios": "^1.7.0",
		"zod": "^3.23.0"
	},
	"devDependencies": {
		"@meta-ads-agent/tsconfig": "workspace:*",
		"vitest": "^2.0.0",
		"@types/node": "^20.0.0"
	}
}
